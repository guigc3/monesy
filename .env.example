# Copie este arquivo como .env e preencha com os valores reais.
# .env nunca deve ser commitado (ver .gitignore).

# =============================================================
# MYSQL 5.6 (UOL Host) — modo recomendado em producao
# =============================================================
MYSQL_HOST=seu-host.uolhost.com.br
MYSQL_PORT=3306
MYSQL_USER=seu_usuario
MYSQL_PASSWORD=sua_senha
MYSQL_DATABASE=nome_do_banco

# Segredo para assinar os JWTs proprios (qualquer string longa e aleatoria)
JWT_SECRET_KEY=troque-por-uma-string-longa-e-aleatoria

# Modo de armazenamento: "mysql", "supabase" ou "json"
# Nao precisa definir se MYSQL_HOST estiver preenchido — o sistema detecta automaticamente.
STORAGE_BACKEND=mysql

# =============================================================
# Supabase (legado — mantenha apenas se ainda usar Supabase)
# =============================================================
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# SUPABASE_JWT_SECRET=super-secret-jwt-string
# DATABASE_URL=postgresql://postgres:senha@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# =============================================================
# Geral
# =============================================================
# Porta do Flask (opcional — padrao 5001)
PORT=5001
